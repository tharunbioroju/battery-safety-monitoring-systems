  {
    lcdPage++;

    if(lcdPage > 4)
      lcdPage = 0;

    lastLCDSwitch = millis();

    lcd.clear();
  }

  switch(lcdPage)
  {
    case 0:

      lcd.setCursor(0,0);
      lcd.print("Pack:");
      lcd.print(pack.packVoltage,2);

      lcd.setCursor(0,1);
      lcd.print(healthLabel(currentHealth));

      break;

    case 1:

      lcd.setCursor(0,0);
      lcd.print("C1:");
      lcd.print(cells[0].voltage,2);

      lcd.setCursor(0,1);
      lcd.print("C2:");
      lcd.print(cells[1].voltage,2);

      break;

    case 2:

      lcd.setCursor(0,0);
      lcd.print("C3:");
      lcd.print(cells[2].voltage,2);

      lcd.setCursor(0,1);
      lcd.print("C4:");
      lcd.print(cells[3].voltage,2);

      break;

    case 3:

      lcd.setCursor(0,0);
      lcd.print("SOC:");
      lcd.print(pack.avgSoc,0);
      lcd.print("%");

      lcd.setCursor(0,1);
      lcd.print("Imb:");
      lcd.print(pack.imbalancePct,1);
      lcd.print("%");

      break;

    case 4:

      lcd.setCursor(0,0);
      lcd.print("W:C");
      lcd.print(pack.weakestCell + 1);

      lcd.setCursor(8,0);
      lcd.print("S:C");
      lcd.print(pack.strongestCell + 1);

      lcd.setCursor(0,1);

      if(WiFi.status()==WL_CONNECTED)
        lcd.print("WiFi OK");
      else
        lcd.print("WiFi LOST");

      break;
  }
}

