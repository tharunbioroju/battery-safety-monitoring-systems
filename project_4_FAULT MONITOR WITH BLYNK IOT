//====================================================
// Loop
//====================================================

void loop()
{
  if(Blynk.connected())
    Blynk.run();

  handleWiFi();

  connectBlynk();

  unsigned long now = millis();

  if(now - lastPoll >= POLL_INTERVAL)
  {
    readBatteryData();

    processBatteryEvents();

    lastPoll = now;
  }

  monitorRSSI();

  if(now - lastTelemetry >= TELEMETRY_INTERVAL)
  {
    sendLiveData();

    syncEventQueue();

    lastTelemetry = now;
  }

  updateLCD();
}
