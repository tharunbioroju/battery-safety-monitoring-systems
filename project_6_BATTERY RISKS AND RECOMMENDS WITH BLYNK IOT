//====================================================
// Event Queue
//====================================================

#define MAX_EVENTS 30

struct EventItem
{
  String message;
};

EventItem eventQueue[MAX_EVENTS];

int queueHead = 0;
int queueTail = 0;

//====================================================
// Queue Functions
//====================================================

bool queueEmpty()  { return queueHead == queueTail; }
bool queueFull()   { return ((queueTail + 1) % MAX_EVENTS) == queueHead; }

void pushEvent(String msg)
{
  if (queueFull()) return;
  eventQueue[queueTail].message = msg;
  queueTail = (queueTail + 1) % MAX_EVENTS;
  Serial.println("[EVENT] " + msg);
}

String popEvent()
{
  if (queueEmpty()) return "";
  String msg = eventQueue[queueHead].message;
  queueHead = (queueHead + 1) % MAX_EVENTS;
  return msg;
}

//====================================================
// Voltage to SOC
//====================================================

float voltageToSOC(float v)
{
  float soc = ((v - V_MIN) / (V_MAX - V_MIN)) * 100.0;
  if (soc < 0)   soc = 0;
  if (soc > 100) soc = 100;
  return soc;
}

//====================================================
// Signal State Label
//====================================================

String getSignalState(int rssi)
{
  if (rssi > -60) return "Excellent";
  if (rssi > -70) return "Good";
  if (rssi > -80) return "Weak";
  return "Poor";
}

